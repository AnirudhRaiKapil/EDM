# Relational storage. Defaults to SQLite (zero install). Swap to Postgres once
# infrastructure/docker/docker-compose.yml is running:
#   postgresql+psycopg2://edm:edm_dev_password@localhost:5432/edm_platform
DATABASE_URL=sqlite:///./edm_platform.db

# Object storage root. Local disk now; swap to a MinIO-backed adapter later.
DATA_DIR=./data

# JWT signing secret. Generate your own with: py -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 bytes -- shorter secrets are logged as an insecure-configuration
# warning at startup (app/main.py) and trigger PyJWT's own InsecureKeyLengthWarning.
JWT_SECRET=change-me-dev-only
JWT_EXPIRE_MINUTES=120

# Key used to encrypt Source credentials at rest (app/secrets.py, Fernet). Any string
# works -- it's SHA-256'd into a real Fernet key -- but treat it like a real secret.
# Generate your own with: py -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_ENCRYPTION_KEY=change-me-dev-only-32-bytes-min!!

# Event bus. "inprocess" logs events locally; "kafka" requires the compose stack
# (see infrastructure/docker/docker-compose.yml) and a bootstrap server.
EVENT_BUS=inprocess
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Comma-separated browser origins allowed to call this API (CORS). The default
# covers the edm-ui Vite dev server. Add your deployed UI's origin in production.
CORS_ORIGINS=http://localhost:5173

# Runs Pipeline cron schedules in a background APScheduler thread (ADR-0010). Tests
# force this off regardless of this value (it's a module-level singleton that would
# otherwise leak state across tests) -- this only affects real `uvicorn` runs.
ENABLE_SCHEDULER=true

# Hard cap on a single file upload (app/modules/ingestion/router.py) -- the request
# is rejected (413) once the body read crosses this, without ever buffering more than
# this much into memory at once.
MAX_UPLOAD_MB=100

# In-process rate limiting on /auth/login and /auth/register, keyed by both client IP
# and target email. Single-process only -- see app/rate_limit.py for why.
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
