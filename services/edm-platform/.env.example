# Relational storage. Defaults to SQLite (zero install). Swap to Postgres once
# infrastructure/docker/docker-compose.yml is running:
#   postgresql+psycopg2://edm:edm_dev_password@localhost:5432/edm_platform
DATABASE_URL=sqlite:///./edm_platform.db

# Object storage root. Local disk now; swap to a MinIO-backed adapter later.
DATA_DIR=./data

# JWT signing secret. Generate your own with: py -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-dev-only
JWT_EXPIRE_MINUTES=120

# Event bus. "inprocess" logs events locally; "kafka" requires the compose stack
# (see infrastructure/docker/docker-compose.yml) and a bootstrap server.
EVENT_BUS=inprocess
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Comma-separated browser origins allowed to call this API (CORS). The default
# covers the edm-ui Vite dev server. Add your deployed UI's origin in production.
CORS_ORIGINS=http://localhost:5173
